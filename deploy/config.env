# Ralph AWS config — fill in AWS_REGION, everything else is auto-detected.
# Source this file before running make commands: source deploy/config.env

AWS_REGION=us-east-1
AWS_ACCOUNT_ID=   # leave blank to auto-detect via STS

ECR_REPO=ralph-runner
ECS_CLUSTER=ralph
TASK_FAMILY=ralph
LOG_GROUP=/ecs/ralph
